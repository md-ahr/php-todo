APP_NAME="PHP Todo"
APP_ENV=local
APP_DEBUG=true

# PHP connects with PDO using DB_* (not DB_ROOT_PASSWORD).
# Same machine as Docker Compose: DB_HOST=127.0.0.1
# PHP app runs inside Compose next to mysql: DB_HOST=mysql
#
# Users table (registration) — apply once per environment:
#   php database/migrate.php
# Or: mysql -u "$DB_USERNAME" -p"$DB_PASSWORD" "$DB_DATABASE" < database/schema.sql

DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=todo
DB_USERNAME=todo
DB_PASSWORD=secret
DB_ROOT_PASSWORD=root

# Free-tier cap for todo rows per user ($-subscription unlocks unlimited).
FREE_TODO_LIMIT=10

# Practice mode: POST /subscribe grants access without a payment provider.
APP_SIMULATE_SUBSCRIPTION_CHECKOUT=true

#
# Image arch (fixes Docker "exec format error" if MySQL container won't start)
# Intel / amd64 Linux: (default in docker-compose; can omit)
# MYSQL_IMAGE_PLATFORM=linux/amd64
# Apple Silicon:
# MYSQL_IMAGE_PLATFORM=linux/arm64
